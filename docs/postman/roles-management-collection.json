{
  "info": {
    "_postman_id": "roles-management-api",
    "name": "Valorize API - Roles Management",
    "description": "Complete collection for testing RBAC Roles Management endpoints\n\n**Base URL**: http://localhost:3000\n\n**Authentication**: All endpoints require a valid Bearer token in the Authorization header\n\n**Features**:\n- List, create, update, and delete roles\n- Manage role permissions\n- Assign roles to users\n- View system permissions\n- Manage user role assignments",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login (Get Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('token', jsonData.access_token);",
                  "    pm.environment.set('user_id', jsonData.user_info.sub);",
                  "    console.log('Token and user_id saved to environment');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "description": "Authenticate and get a Bearer token. The token will be automatically saved to the environment variable `token`."
        }
      ]
    },
    {
      "name": "Roles - List & Get",
      "item": [
        {
          "name": "List All Roles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/roles?limit=50&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "roles"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Maximum number of roles to return (default: 50, max: 100)"
                },
                {
                  "key": "offset",
                  "value": "0",
                  "description": "Number of roles to skip (default: 0)"
                }
              ]
            },
            "description": "Retrieve a paginated list of all roles for the company.\n\n**Required Permission**: `roles:read`"
          }
        },
        {
          "name": "Get Role by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/roles/{{role_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "roles",
                "{{role_id}}"
              ]
            },
            "description": "Retrieve detailed information about a specific role.\n\n**Required Permission**: `roles:read`\n\n**Path Parameters**:\n- `role_id`: The unique identifier of the role"
          }
        }
      ]
    },
    {
      "name": "Roles - Create & Update",
      "item": [
        {
          "name": "Create Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('role_id', jsonData.data.id);",
                  "    console.log('Role ID saved:', jsonData.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Content Manager\",\n  \"description\": \"Manages company content and documents\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/roles",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "roles"
              ]
            },
            "description": "Create a new role for the company.\n\n**Required Permission**: `roles:create`\n\n**Request Body**:\n- `name` (string, required): Unique name of the role\n- `description` (string, optional): Description of the role's purpose"
          }
        },
        {
          "name": "Update Role",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Senior Content Manager\",\n  \"description\": \"Manages company content, documents, and approves publications\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/roles/{{role_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "roles",
                "{{role_id}}"
              ]
            },
            "description": "Update an existing role's name and/or description.\n\n**Required Permission**: `roles:update`\n\n**Path Parameters**:\n- `role_id`: The unique identifier of the role to update\n\n**Request Body**:\n- `name` (string, optional): New name for the role\n- `description` (string, optional): New description for the role"
          }
        }
      ]
    },
    {
      "name": "Roles - Delete",
      "item": [
        {
          "name": "Delete Role",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/roles/{{role_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "roles",
                "{{role_id}}"
              ]
            },
            "description": "Delete a role. The role must not have any users assigned to it.\n\n**Required Permission**: `roles:delete`\n\n**Path Parameters**:\n- `role_id`: The unique identifier of the role to delete\n\n**Error Codes**:\n- `ROLE_HAS_USERS`: Cannot delete a role that has users assigned to it"
          }
        }
      ]
    },
    {
      "name": "Role Permissions - Manage",
      "item": [
        {
          "name": "Set Role Permissions (Replace All)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permissions\": [\n    \"roles:read\",\n    \"roles:update\",\n    \"users:read\",\n    \"users:update\",\n    \"compliments:read\",\n    \"compliments:create\"\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/roles/{{role_id}}/permissions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "roles",
                "{{role_id}}",
                "permissions"
              ]
            },
            "description": "Set all permissions for a role. This replaces all existing permissions.\n\n**Required Permission**: `roles:update`\n\n**Path Parameters**:\n- `role_id`: The unique identifier of the role\n\n**Request Body**:\n- `permissions` (array of strings, required): List of permission codes to assign\n\n**Note**: Use this to replace all permissions at once."
          }
        },
        {
          "name": "Add Permission to Role",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permission\": \"prizes:read\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/roles/{{role_id}}/permissions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "roles",
                "{{role_id}}",
                "permissions"
              ]
            },
            "description": "Add a single permission to a role.\n\n**Required Permission**: `roles:update`\n\n**Path Parameters**:\n- `role_id`: The unique identifier of the role\n\n**Request Body**:\n- `permission` (string, required): The permission code to add"
          }
        },
        {
          "name": "Remove Permission from Role",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permission\": \"prizes:read\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/roles/{{role_id}}/permissions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "roles",
                "{{role_id}}",
                "permissions"
              ]
            },
            "description": "Remove a single permission from a role.\n\n**Required Permission**: `roles:update`\n\n**Path Parameters**:\n- `role_id`: The unique identifier of the role\n\n**Request Body**:\n- `permission` (string, required): The permission code to remove"
          }
        }
      ]
    },
    {
      "name": "User Roles - Manage",
      "item": [
        {
          "name": "Assign Role to User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleId\": \"{{role_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/roles/users/{{user_id}}/roles",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "roles",
                "users",
                "{{user_id}}",
                "roles"
              ]
            },
            "description": "Assign a role to a user.\n\n**Required Permission**: `users:manage_roles`\n\n**Path Parameters**:\n- `user_id`: The unique identifier of the user\n\n**Request Body**:\n- `roleId` (string, required): The unique identifier of the role to assign"
          }
        },
        {
          "name": "Remove Role from User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{base_url}}/admin/roles/users/{{user_id}}/roles/{{role_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "roles",
                "users",
                "{{user_id}}",
                "roles",
                "{{role_id}}"
              ]
            },
            "description": "Remove a role from a user.\n\n**Required Permission**: `users:manage_roles`\n\n**Path Parameters**:\n- `user_id`: The unique identifier of the user\n- `role_id`: The unique identifier of the role to remove"
          }
        },
        {
          "name": "Get User Roles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/roles/users/{{user_id}}/roles",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "roles",
                "users",
                "{{user_id}}",
                "roles"
              ]
            },
            "description": "Get all roles assigned to a specific user.\n\n**Required Permission**: `users:read`\n\n**Path Parameters**:\n- `user_id`: The unique identifier of the user"
          }
        }
      ]
    },
    {
      "name": "System Permissions",
      "item": [
        {
          "name": "Get All System Permissions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/roles/system/permissions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "roles",
                "system",
                "permissions"
              ]
            },
            "description": "Retrieve all available system permissions organized by category.\n\n**Required Permission**: `roles:read`\n\n**Response**: Returns permissions grouped by feature categories (e.g., users, roles, compliments, etc.)"
          }
        },
        {
          "name": "Get Permissions by Category",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/roles/system/categories",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "roles",
                "system",
                "categories"
              ]
            },
            "description": "Get all available permission categories.\n\n**Required Permission**: `roles:read`\n\n**Response**: Returns a list of all permission categories available in the system"
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Set default base URL if not already set",
          "if (!pm.environment.get('base_url')) {",
          "    pm.environment.set('base_url', 'http://localhost:3000');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "Base URL for the Valorize API"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Bearer token obtained from login"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string",
      "description": "Current user ID from authentication"
    },
    {
      "key": "role_id",
      "value": "",
      "type": "string",
      "description": "Role ID for testing (set automatically when creating a role)"
    }
  ]
}
