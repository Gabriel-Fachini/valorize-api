	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{auth_token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Script Pre-Request Global - Renovação Automática de Token (VERSÃO SÍNCRONA)",
					"const currentUrl = pm.request.url.toString();",
					"",
					"// Pular verificação para requisições de autenticação",
					"if (currentUrl.includes('/auth/login') || currentUrl.includes('/auth/refresh')) {",
					"    console.log('🔄 Pulando verificação de token para endpoint de auth');",
					"    return;",
					"}",
					"",
					"const token = pm.environment.get('auth_token');",
					"const refreshToken = pm.environment.get('refresh_token');",
					"const tokenExpiry = pm.environment.get('token_expiry');",
					"",
					"console.log('🔍 Verificando token atual:', token ? token.substring(0, 20) + '...' : 'Não encontrado');",
					"console.log('🔄 Refresh token disponível:', !!refreshToken);",
					"",
					"// Verificar se o token é claramente inválido",
					"const isInvalidToken = !token || ",
					"    token === 'abc' || ",
					"    token === 'token_invalido_para_teste' || ",
					"    token.length < 10;",
					"",
					"// Verificar se o token está expirado",
					"let isExpired = false;",
					"if (tokenExpiry) {",
					"    const now = new Date().getTime();",
					"    const expiryTime = parseInt(tokenExpiry);",
					"    const timeRemaining = expiryTime - now;",
					"    isExpired = timeRemaining <= 0;",
					"    ",
					"    if (isExpired) {",
					"        console.log('⏰ Token expirado!');",
					"    } else {",
					"        console.log('⏰ Token expira em:', Math.floor(timeRemaining / 1000 / 60), 'minutos');",
					"    }",
					"}",
					"",
					"// Se o token é inválido ou expirado E temos refresh token",
					"if ((isInvalidToken || isExpired) && refreshToken) {",
					"    console.log('🔄 Iniciando renovação do token...');",
					"    ",
					"    // Criar requisição de refresh de forma síncrona",
					"    const refreshRequest = {",
					"        url: pm.environment.get('base_url') + '/auth/refresh',",
					"        method: 'POST',",
					"        header: {",
					"            'Content-Type': 'application/json',",
					"        },",
					"        body: {",
					"            mode: 'raw',",
					"            raw: JSON.stringify({",
					"                refresh_token: refreshToken",
					"            })",
					"        }",
					"    };",
					"    ",
					"    // Usar pm.sendRequest de forma síncrona",
					"    let refreshCompleted = false;",
					"    let refreshSuccess = false;",
					"    ",
					"    pm.sendRequest(refreshRequest, (err, response) => {",
					"        if (err) {",
					"            console.log('❌ Erro ao renovar token:', err);",
					"            refreshCompleted = true;",
					"            return;",
					"        }",
					"        ",
					"        console.log('📞 Status da renovação:', response.code);",
					"        ",
					"        if (response.code === 200) {",
					"            const responseJson = response.json();",
					"            console.log('📦 Resposta do refresh:', responseJson);",
					"            ",
					"            if (responseJson.success && responseJson.data) {",
					"                const { access_token, refresh_token: newRefreshToken, expires_in } = responseJson.data;",
					"                ",
					"                // Atualizar tokens no ambiente",
					"                pm.environment.set('auth_token', access_token);",
					"                if (newRefreshToken) {",
					"                    pm.environment.set('refresh_token', newRefreshToken);",
					"                }",
					"                ",
					"                // Atualizar tempo de expiração",
					"                const now = new Date().getTime();",
					"                const expiryTime = now + (expires_in * 1000);",
					"                pm.environment.set('token_expiry', expiryTime.toString());",
					"                ",
					"                console.log('✅ Token renovado automaticamente!');",
					"                console.log('🔑 Novo token:', access_token.substring(0, 20) + '...');",
					"                console.log('⏰ Expira em:', new Date(expiryTime).toLocaleString());",
					"                ",
					"                refreshSuccess = true;",
					"            } else {",
					"                console.log('❌ Resposta inválida do refresh:', responseJson);",
					"            }",
					"        } else {",
					"            console.log('❌ Falha ao renovar token. Status:', response.code);",
					"            const errorResponse = response.json();",
					"            console.log('Erro:', errorResponse);",
					"        }",
					"        ",
					"        refreshCompleted = true;",
					"    });",
					"    ",
					"    // Aguardar a conclusão da renovação (timeout de 5 segundos)",
					"    const startTime = Date.now();",
					"    while (!refreshCompleted && (Date.now() - startTime) < 5000) {",
					"        // Aguardar",
					"    }",
					"    ",
					"    if (!refreshCompleted) {",
					"        console.log('⏱️ Timeout na renovação do token');",
					"    } else if (refreshSuccess) {",
					"        console.log('✅ Renovação concluída com sucesso!');",
					"    } else {",
					"        console.log('❌ Renovação falhou');",
					"    }",
					"    ",
					"} else if ((isInvalidToken || isExpired) && !refreshToken) {",
					"    console.log('❌ Token inválido/expirado e sem refresh token. Faça login novamente.');",
					"} else {",
					"    console.log('✅ Token parece válido, prosseguindo com a requisição...');",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Script Post-Request Global - Tratamento de Erros de Autenticação",
					"const currentUrl = pm.request.url.toString();",
					"",
					"// Pular para requisições de auth",
					"if (currentUrl.includes('/auth/login') || currentUrl.includes('/auth/refresh')) {",
					"    return;",
					"}",
					"",
					"// Log da resposta para debug",
					"console.log('📞 Status da resposta:', pm.response.code);",
					"",
					"// Se recebeu 401 Unauthorized",
					"if (pm.response.code === 401) {",
					"    const responseJson = pm.response.json();",
					"    console.log('🚫 Recebido 401 Unauthorized:', responseJson.message || responseJson.error);",
					"    ",
					"    // Marcar token como inválido para forçar renovação na próxima requisição",
					"    pm.environment.set('auth_token', 'token_invalido_401');",
					"    pm.environment.set('token_expiry', '0');",
					"    ",
					"    console.log('⚠️ Token marcado como inválido. Na próxima requisição, será renovado automaticamente.');",
					"} else if (pm.response.code === 200) {",
					"    console.log('✅ Requisição bem-sucedida!');",
					"}"
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:4000",
			"type": "string"
		}
	]
}