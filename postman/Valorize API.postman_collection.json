		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Script para capturar tokens após login bem-sucedido",
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    ",
									"    // A API retorna: { success: true, data: { access_token, refresh_token, expires_in } }",
									"    if (responseJson.success && responseJson.data) {",
									"        const { access_token, refresh_token, expires_in } = responseJson.data;",
									"        ",
									"        // Salvar tokens",
									"        pm.environment.set(\"auth_token\", access_token);",
									"        if (refresh_token) {",
									"            pm.environment.set(\"refresh_token\", refresh_token);",
									"        }",
									"        ",
									"        // Calcular e salvar tempo de expiração",
									"        const now = new Date().getTime();",
									"        const expiryTime = now + (expires_in * 1000); // expires_in em segundos",
									"        pm.environment.set(\"token_expiry\", expiryTime.toString());",
									"        ",
									"        console.log(\"✅ Login realizado com sucesso!\");",
									"        console.log(\"🔑 Token salvo:\", access_token.substring(0, 20) + \"...\");",
									"        console.log(\"🔄 Refresh token salvo\");",
									"        console.log(\"⏰ Token expira em:\", new Date(expiryTime).toLocaleString());",
									"    }",
									"} else {",
									"    console.log(\"❌ Erro no login:\", pm.response.json());",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"gabriel.fachini@usevalorize.com.br\",\n    \"password\": \"V@alorize\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						}
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Script para capturar tokens após refresh bem-sucedido",
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    ",
									"    // A API retorna: { success: true, data: { access_token, refresh_token, expires_in } }",
									"    if (responseJson.success && responseJson.data) {",
									"        const { access_token, refresh_token, expires_in } = responseJson.data;",
									"        ",
									"        // Salvar novos tokens",
									"        pm.environment.set(\"auth_token\", access_token);",
									"        if (refresh_token) {",
									"            pm.environment.set(\"refresh_token\", refresh_token);",
									"        }",
									"        ",
									"        // Calcular e salvar tempo de expiração",
									"        const now = new Date().getTime();",
									"        const expiryTime = now + (expires_in * 1000); // expires_in em segundos",
									"        pm.environment.set(\"token_expiry\", expiryTime.toString());",
									"        ",
									"        console.log(\"✅ Token renovado com sucesso!\");",
									"        console.log(\"🔑 Novo token salvo:\", access_token.substring(0, 20) + \"...\");",
									"        console.log(\"⏰ Token expira em:\", new Date(expiryTime).toLocaleString());",
									"    }",
									"} else {",
									"    console.log(\"❌ Erro no refresh:\", pm.response.json());",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh_token\": \"{{refresh_token}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/refresh",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"refresh"
							]
						}
					},
					"response": []
				},
