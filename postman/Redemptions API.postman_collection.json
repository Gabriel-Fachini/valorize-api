          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"prizeId\": \"clh9876543210zyxwvutsrqp\",\n  \"variantId\": \"variant-id-optional\",\n  \"addressId\": \"clh5555555555555555555555\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/redemptions/redeem",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "redemptions",
            "redeem"
          ]
        },
        "description": "User redeems a prize using their redeemable balance\n\n**Request Body**:\n- `prizeId` (string): CUID of the prize\n- `variantId` (string, optional): For prizes with variants\n- `addressId` (string): Address for shipping/delivery\n\n**Response**: 201 Created\n- `redemption`: Full redemption object with status, coins spent, etc.\n\n**Possible Errors**:\n- 400: Insufficient balance\n- 409: Insufficient stock\n- 400: Variant required for this prize"
      },
      "response": [
        {
          "name": "201 Created - Prize Redeemed",
          "originalRequest": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{base_url}}/redemptions/redeem",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "redemptions",
                "redeem"
              ]
            }
          },
          "status": "Created",
          "code": 201,
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"message\": \"Prize redeemed successfully\",\n  \"redemption\": {\n    \"id\": \"clr1234567890abcdefghijkl\",\n    \"userId\": \"clh1234567890abcdefghijk\",\n    \"prizeId\": \"clh9876543210zyxwvutsrqp\",\n    \"coinsSpent\": 100,\n    \"status\": \"completed\",\n    \"createdAt\": \"2025-11-09T10:30:00Z\",\n    \"updatedAt\": \"2025-11-09T10:30:00Z\"\n  }\n}"
        }
      ]
    },
    {
