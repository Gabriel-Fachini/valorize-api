            "key": "Authorization",
            "value": "Bearer {{auth_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/redemptions/my-redemptions?limit=20&offset=0",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "redemptions",
            "my-redemptions"
          ],
          "query": [
            {
              "key": "limit",
              "value": "20",
              "type": "text"
            },
            {
              "key": "offset",
              "value": "0",
              "type": "text"
            }
          ]
        },
        "description": "Get the authenticated user's redemption history\n\n**Query Parameters**:\n- `limit` (number, default: 20): Results per page (max: 100)\n- `offset` (number, default: 0): Pagination offset\n\n**Response**: 200 OK\n- `redemptions`: Array of redemption objects\n- `meta`: Pagination metadata"
      },
