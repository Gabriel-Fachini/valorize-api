          "body": "{\n  \"redemptions\": [\n    {\n      \"id\": \"clr1111111111111111111111\",\n      \"userId\": \"clh1234567890abcdefghijk\",\n      \"prizeId\": \"clh9876543210zyxwvutsrqp\",\n      \"coinsSpent\": 100,\n      \"status\": \"completed\",\n      \"createdAt\": \"2025-11-08T15:00:00Z\",\n      \"updatedAt\": \"2025-11-08T15:00:00Z\"\n    },\n    {\n      \"id\": \"clr2222222222222222222222\",\n      \"userId\": \"clh1234567890abcdefghijk\",\n      \"prizeId\": \"clh1111111111111111111111\",\n      \"coinsSpent\": 50,\n      \"status\": \"cancelled\",\n      \"createdAt\": \"2025-11-07T10:30:00Z\",\n      \"updatedAt\": \"2025-11-08T09:00:00Z\"\n    }\n  ],\n  \"meta\": {\n    \"limit\": 20,\n    \"offset\": 0,\n    \"count\": 2\n  }\n}"
