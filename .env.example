# Database Configuration (Prisma)
DATABASE_URL=postgresql://valorize_user:password@localhost:5432/valorize_db

# IMPORTANT: For local development, ensure your PostgreSQL user has CREATEDB permission
# This is required for Prisma Migrate to create shadow databases during development
# To grant this permission, run as a superuser (e.g., your system user):
# psql -h localhost -U <superuser> -d postgres -c "ALTER USER valorize_user CREATEDB;"

# Auth0 Configuration
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# Auth0 Signup Configuration
AUTH0_M2M_DOMAIN=your-domain.auth0.com
AUTH0_M2M_AUDIENCE=https://your-api-identifier
AUTH0_M2M_CLIENT_ID=your-auth0-client-id
AUTH0_M2M_CLIENT_SECRET=your-auth0-client-secret

# API Configuration
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
API_VERSION=v1
API_PREFIX=/api/v1

# CORS Configuration
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=60000

# Logging
LOG_LEVEL=debug

# Redis Configuration (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Tremendous API Configuration
# Get your API key from: https://testflight.tremendous.com/api_keys (sandbox)
# Or: https://www.tremendous.com/api_keys (production)
TREMENDOUS_API_KEY=your-tremendous-api-key
TREMENDOUS_BASE_URL=https://testflight.tremendous.com/api/v2
TREMENDOUS_FUNDING_SOURCE_ID=BALANCE