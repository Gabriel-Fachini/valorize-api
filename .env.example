# ============================================================================
# Valorize API - Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual configuration values.
# Never commit .env to version control. It's in .gitignore for security.
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL via Prisma)
# ============================================================================

DATABASE_URL=postgresql://valorize_user:password@localhost:5432/valorize_db

# For local development, ensure your PostgreSQL user has CREATEDB permission
# This is required for Prisma Migrate to create shadow databases during development.
# To grant this permission, run as superuser:
# psql -h localhost -U <superuser> -d postgres -c "ALTER USER valorize_user CREATEDB;"

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Server port (default: 4000)
PORT=4000

# Server host
HOST=0.0.0.0

# Environment: development, test, or production
NODE_ENV=development

# ============================================================================
# CORS & SECURITY
# ============================================================================

# Frontend URL for CORS configuration
CORS_ORIGIN=http://localhost:3001

# Allow credentials in CORS requests
CORS_CREDENTIALS=true

# ============================================================================
# RATE LIMITING
# ============================================================================

# Maximum requests per time window
RATE_LIMIT_MAX=100

# Time window in milliseconds (60000 = 1 minute)
RATE_LIMIT_TIME_WINDOW=60000

# ============================================================================
# LOGGING
# ============================================================================

# Log level: error, warn, info, debug, trace
LOG_LEVEL=debug

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================

# --- Supabase Auth ---
# Get these values from: https://supabase.com/dashboard/project/_/settings/api

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (public) key - safe for frontend
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key - keep secret, backend only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase JWT secret (for token validation)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Storage bucket for prize images
SUPABASE_STORAGE_BUCKET=prize-images

# --- Tremendous Voucher Service ---
# API keys from: https://testflight.tremendous.com (sandbox)
# Or: https://www.tremendous.com (production)

# Tremendous API key
TREMENDOUS_API_KEY=your-api-key-here

# Tremendous API base URL
# Sandbox: https://testflight.tremendous.com/api/v2
# Production: https://api.tremendous.com/api/v2
TREMENDOUS_BASE_URL=https://testflight.tremendous.com/api/v2

# Tremendous funding source ID
TREMENDOUS_FUNDING_SOURCE_ID=BALANCE

# Tremendous campaign ID (for organizing vouchers)
TREMENDOUS_CAMPAIGN_ID=your-campaign-id

# Tremendous webhook secret (for validating webhooks)
TREMENDOUS_WEBHOOK_SECRET=your-webhook-secret

# --- GitHub Integration (Optional) ---
# For GitHub API interactions (if needed)
GITHUB_API_KEY=your-github-token

# ============================================================================
# FRONTEND URLS (for authentication redirects)
# ============================================================================

# Main frontend URL
FRONTEND_URL=http://localhost:3000

# Password reset page URL
FRONTEND_PASSWORD_RESET_URL=http://localhost:3000/reset-password

# Email confirmation page URL
FRONTEND_EMAIL_CONFIRM_URL=http://localhost:3000/confirm-email

# Invitation/signup page URL
FRONTEND_SIGNUP_URL=http://localhost:3000/signup

# ============================================================================
# AUTH0 (DEPRECATED - LEGACY ONLY)
# ============================================================================
# NOTE: The project has migrated to Supabase Auth.
# These variables are kept for backwards compatibility only.
# Remove them if you're setting up a fresh environment.

# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_CLIENT_SECRET=your-client-secret
# AUTH0_AUDIENCE=https://your-api-identifier
# AUTH0_SCOPE=openid profile email offline_access

# Auth0 M2M (Machine-to-Machine) - for service-to-service auth
# AUTH0_M2M_DOMAIN=your-tenant.auth0.com
# AUTH0_M2M_CLIENT_ID=your-m2m-client-id
# AUTH0_M2M_CLIENT_SECRET=your-m2m-client-secret
# AUTH0_M2M_AUDIENCE=https://your-api-identifier
# AUTH0_PASSWORD_RESET_REDIRECT_URI=http://localhost:3000/reset-password

# ============================================================================
# ENVIRONMENT-SPECIFIC EXAMPLES
# ============================================================================

# --- LOCAL DEVELOPMENT ---
# NODE_ENV=development
# DATABASE_URL=postgresql://valorize_user:password@localhost:5432/valorize_db
# PORT=4000
# LOG_LEVEL=debug

# --- TESTING ---
# NODE_ENV=test
# DATABASE_URL=postgresql://valorize_test:password@localhost:5432/valorize_test
# PORT=3001
# LOG_LEVEL=warn

# --- PRODUCTION ---
# NODE_ENV=production
# DATABASE_URL=postgresql://user:secure-password@prod-db.example.com:5432/valorize_prod
# PORT=4000
# LOG_LEVEL=warn
# CORS_ORIGIN=https://app.valorize.com
