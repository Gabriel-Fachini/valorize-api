{
  "name": "valorize-api",
  "version": "1.0.0",
  "description": "B2B culture and engagement platform API",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "migrate:up": "tsx src/shared/infrastructure/database/migrate.ts up",
    "migrate:down": "tsx src/shared/infrastructure/database/migrate.ts down",
    "migrate:create": "tsx src/shared/infrastructure/database/migrate.ts create",
    "docs:generate": "tsx src/scripts/generate-docs.ts"
  },
  "dependencies": {
    "@fastify/cors": "^8.4.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.12.0",
    "@fastify/swagger-ui": "^2.1.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "fastify": "^4.24.3",
    "jwks-rsa": "^3.1.0",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "@types/pg": "^8.10.7",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.54.0",
    "tsx": "^4.2.0",
    "typescript": "^5.2.2",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "api",
    "fastify",
    "typescript",
    "postgresql",
    "auth0",
    "culture",
    "engagement"
  ],
  "author": "Gabriel Fachini",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
