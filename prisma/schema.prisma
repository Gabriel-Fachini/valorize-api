datasource db {
  url      = env("DATABASE_URL")
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================================
// ENUMS
// ============================================================================

enum RedemptionStatus {
  // Vouchers (Digital)
  SENT
  FAILED

  // Physical Products
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model User {
  id           String   @id @default(cuid())
  auth0Id      String   @unique @map("auth0_id")
  email        String   @unique
  name         String
  avatar       String?
  companyId    String   @map("company_id")
  jobTitleId   String?  @map("job_title_id")
  departmentId String?  @map("department_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roles              UserRole[]
  company            Company             @relation(fields: [companyId], references: [id])
  jobTitle           JobTitle?           @relation(fields: [jobTitleId], references: [id])
  department         Department?         @relation(fields: [departmentId], references: [id])
  companyContacts    CompanyContact[]
  wallet             Wallet?
  walletTransactions WalletTransaction[]

  complimentsSent     Compliment[] @relation("ComplimentSender")
  complimentsReceived Compliment[] @relation("ComplimentReceiver")

  redemptions Redemption[]
  addresses   Address[]

  @@index([companyId])
  @@index([jobTitleId])
  @@index([departmentId])
  @@map("users")
}

model Department {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users   User[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("departments")
}

model JobTitle {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users   User[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("job_titles")
}

model Role {
  id          String   @id @default(cuid())
  name        String
  description String?
  companyId   String   @map("company_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       UserRole[]
  company     Company          @relation(fields: [companyId], references: [id])

  @@unique([name, companyId])
  @@index([companyId])
  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  category    String

  roles RolePermission[]

  @@index([category])
  @@map("permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Company {
  id        String   @id @default(cuid())
  name      String // Nome fantasia
  logoUrl   String?  @map("logo_url") // URL da logo da empresa
  domain    String   @unique // Para verificação de email no login (domínio principal)
  country   String   @default("BR") // Código do país
  timezone  String   @default("America/Sao_Paulo")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relacionamentos
  users          User[]
  roles          Role[]
  departments    Department[]
  jobTitles      JobTitle[]
  companyBrazil  CompanyBrazil?
  contacts       CompanyContact[]
  settings       CompanySettings?
  values         CompanyValue[]
  compliments    Compliment[]
  prizes         Prize[]
  redemptions    Redemption[]
  allowedDomains AllowedDomain[] // Domínios permitidos para SSO
  wallet         CompanyWallet?

  @@index([domain])
  @@index([country])
  @@index([isActive])
  @@map("companies")
}

model CompanyBrazil {
  id                 String   @id @default(cuid())
  companyId          String   @unique @map("company_id")
  cnpj               String   @unique
  razaoSocial        String   @map("razao_social") // Razão social
  inscricaoEstadual  String?  @map("inscricao_estadual") // IE
  inscricaoMunicipal String?  @map("inscricao_municipal") // IM
  nire               String?  @unique // Número de Identificação do Registro de Empresas
  cnaePrincipal      String   @map("cnae_principal") // Atividade econômica principal
  cnaeSecundario     String?  @map("cnae_secundario") // Atividades secundárias
  naturezaJuridica   String   @map("natureza_juridica") // Forma jurídica
  porteEmpresa       String   @map("porte_empresa") // MEI, ME, EPP, etc.
  situacaoCadastral  String   @map("situacao_cadastral") // Ativa, Suspensa, etc.
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([cnpj])
  @@index([situacaoCadastral])
  @@map("companies_brazil")
}

model CompanyContact {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  userId    String   @map("user_id")
  role      String // CEO, CFO, CTO, HR Manager, etc.
  isPrimary Boolean  @default(false) @map("is_primary") // Contato principal
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId]) // Um usuário pode ser contato apenas uma vez por empresa
  @@index([companyId])
  @@index([userId])
  @@index([isPrimary])
  @@map("company_contacts")
}

model CompanySettings {
  id                  Int      @id @default(autoincrement())
  companyId           String   @unique @map("company_id")
  weeklyRenewalAmount Int      @default(100) @map("weekly_renewal_amount") // Quantidade de moedas semanais (50-500)
  renewalDay          Int      @default(1) @map("renewal_day") // Dia da renovação (1=Monday, 7=Sunday)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

model AllowedDomain {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  domain    String // Domínio permitido para SSO (ex: "empresax.com.br")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, domain])
  @@index([companyId])
  @@map("allowed_domains")
}

model CompanyValue {
  id          Int      @id @default(autoincrement())
  companyId   String   @map("company_id")
  title       String
  description String?
  example     String?
  iconName    String?
  iconColor   String?
  order       Int
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  compliments Compliment[]

  @@unique([companyId, title])
  @@index([companyId])
  @@index([companyId, order])
  @@index([isActive])
  @@map("company_values")
}

model Wallet {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  complimentBalance Int      @default(100) @map("compliment_balance")
  redeemableBalance Int      @default(0) @map("redeemable_balance")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([complimentBalance])
  @@map("wallets")
}

model Compliment {
  id         String   @id @default(cuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  companyId  String   @map("company_id")
  valueId    Int      @map("value_id")
  message    String
  coins      Int
  isPublic   Boolean  @default(true) @map("is_public")
  createdAt  DateTime @default(now()) @map("created_at")

  sender       User         @relation("ComplimentSender", fields: [senderId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  receiver     User         @relation("ComplimentReceiver", fields: [receiverId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  company      Company      @relation(fields: [companyId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  companyValue CompanyValue @relation(fields: [valueId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@index([senderId])
  @@index([receiverId])
  @@index([companyId])
  @@index([valueId])
  @@index([createdAt])
  @@index([companyId, createdAt])
  @@map("compliments")
}

model WalletTransaction {
  id              String   @id @default(cuid())
  walletId        String   @map("wallet_id")
  userId          String   @map("user_id")
  transactionType String   @map("transaction_type") // DEBIT, CREDIT, RESET
  balanceType     String   @map("balance_type") // COMPLIMENT, REDEEMABLE
  amount          Int
  previousBalance Int      @map("previous_balance")
  newBalance      Int      @map("new_balance")
  reason          String // Reason for the transaction
  metadata        Json? // Additional data (compliment ID, admin ID, etc.)
  createdAt       DateTime @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([userId])
  @@index([transactionType])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("wallet_transactions")
}

model Prize {
  id             String   @id @default(cuid())
  companyId      String?  @map("company_id")
  name           String
  description    String
  type           String // "voucher", "physical" - Prize delivery type
  category       String? // Business category (e.g., "Alimentação", "Tecnologia", "Gastronomia")
  images         String[]
  coinPrice      Int      @map("coin_price")
  brand          String?
  specifications Json? // Maintains flexible data structure for prize specifications
  stock          Int      @default(0)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  company     Company?       @relation(fields: [companyId], references: [id])
  variants    PrizeVariant[]
  redemptions Redemption[]

  // Relacionamentos específicos por tipo (1:1 opcional)
  voucherPrize VoucherPrize? // Se type = "voucher"
  // productPrize ProductPrize? // FUTURO: Se type = "product"

  @@index([companyId, isActive, stock])
  @@index([type])
  @@index([category])
  @@map("prizes")
}

model PrizeVariant {
  id       String  @id @default(cuid())
  prizeId  String  @map("prize_id")
  name     String
  value    String
  stock    Int     @default(0)
  isActive Boolean @default(true) @map("is_active")

  prize       Prize        @relation(fields: [prizeId], references: [id], onDelete: Cascade)
  redemptions Redemption[]

  @@index([prizeId])
  @@map("prize_variants")
}

model Address {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  name         String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String   @map("zip_code")
  country      String   @default("BR")
  phone        String
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  redemptions Redemption[]

  @@index([userId])
  @@index([userId, isDefault])
  @@map("addresses")
}

model Redemption {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  prizeId      String   @map("prize_id")
  variantId    String?  @map("variant_id")
  companyId    String   @map("company_id")
  addressId    String?  @map("address_id") // OPCIONAL agora (NULL para vouchers)
  coinsSpent   Int      @map("coins_spent")
  status       RedemptionStatus @default(PENDING)
  trackingCode String?  @map("tracking_code") // Manter para compatibilidade
  redeemedAt   DateTime @default(now()) @map("redeemed_at")

  user     User                 @relation(fields: [userId], references: [id])
  prize    Prize                @relation(fields: [prizeId], references: [id])
  variant  PrizeVariant?        @relation(fields: [variantId], references: [id])
  company  Company              @relation(fields: [companyId], references: [id])
  address  Address?             @relation(fields: [addressId], references: [id]) // OPCIONAL
  tracking RedemptionTracking[]

  // Relacionamentos específicos por tipo (1:1 opcional)
  voucherRedemption VoucherRedemption? // Se category = "voucher"
  webhookLogs       TremendousWebhookLog[]

  @@index([userId, redeemedAt])
  @@index([companyId, status])
  @@index([prizeId])
  @@index([addressId])
  @@map("redemptions")
}

model RedemptionTracking {
  id           String   @id @default(cuid())
  redemptionId String   @map("redemption_id")
  status       RedemptionStatus
  notes        String?
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  redemption Redemption @relation(fields: [redemptionId], references: [id], onDelete: Cascade)

  @@index([redemptionId, createdAt])
  @@map("redemption_tracking")
}

model CompanyWallet {
  id             String   @id @default(cuid())
  companyId      String   @unique @map("company_id")
  balance        Decimal  @default(0) @db.Decimal(10, 2)
  totalDeposited Decimal  @default(0) @map("total_deposited") @db.Decimal(10, 2)
  totalSpent     Decimal  @default(0) @map("total_spent") @db.Decimal(10, 2)
  overdraftLimit Decimal  @default(0) @map("overdraft_limit") @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deposits WalletDeposit[]

  @@index([companyId])
  @@index([balance])
  @@map("company_wallets")
}

model WalletDeposit {
  id              String   @id @default(cuid())
  companyWalletId String   @map("company_wallet_id")
  amount          Decimal  @db.Decimal(10, 2)
  status          String   @default("completed")
  paymentMethod   String?  @map("payment_method")
  transactionId   String?  @map("transaction_id")
  notes           String?
  createdBy       String?  @map("created_by")
  depositedAt     DateTime @default(now()) @map("deposited_at")
  createdAt       DateTime @default(now()) @map("created_at")

  companyWallet CompanyWallet @relation(fields: [companyWalletId], references: [id], onDelete: Cascade)

  @@index([companyWalletId])
  @@index([status])
  @@index([depositedAt])
  @@index([companyWalletId, depositedAt])
  @@map("wallet_deposits")
}

// ============================================================================
// VOUCHER SYSTEM - Tables for integration with voucher providers
// ============================================================================

model VoucherRedemption {
  id           String @id @default(cuid())
  redemptionId String @unique @map("redemption_id") // 1:1 com Redemption

  // Informações do provider
  provider         String // "tremendous", "giftty", "incentivar"
  providerOrderId  String? @map("provider_order_id") // ID do pedido no provider
  providerRewardId String? @map("provider_reward_id") // ID do voucher no provider

  // Dados do voucher
  voucherLink String? @map("voucher_link") // Link para acessar/resgatar
  voucherCode String? @map("voucher_code") // Código do voucher (se houver)
  amount      Decimal @db.Decimal(10, 2) // Valor em reais
  currency    String  @default("BRL")

  // Controle de status e retry
  status       RedemptionStatus @default(SENT) // SENT when email delivered, FAILED if delivery fails
  errorMessage String?   @map("error_message") // Mensagem de erro (se houver)
  retryCount   Int       @default(0) @map("retry_count")
  lastRetryAt  DateTime? @map("last_retry_at")

  // Timestamps
  completedAt DateTime? @map("completed_at")
  expiresAt   DateTime? @map("expires_at") // Data de expiração do voucher
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relacionamento 1:1 com Redemption
  redemption Redemption @relation(fields: [redemptionId], references: [id], onDelete: Cascade)

  @@index([status, retryCount])
  @@index([provider, providerOrderId])
  @@index([createdAt])
  @@map("voucher_redemptions")
}

model VoucherProduct {
  id String @id @default(cuid())

  // Identificação do provider
  provider   String // "tremendous", "giftty"
  externalId String @map("external_id") // ID do produto no provider

  // Dados do produto
  name        String
  description String?
  category    String // "gift-card", "charity", "paypal"
  brand       String?
  images      String[] // URLs das imagens do produto

  // Valores permitidos
  minValue  Decimal  @map("min_value") @db.Decimal(10, 2)
  maxValue  Decimal  @map("max_value") @db.Decimal(10, 2)
  currency  String   @default("BRL")
  countries String[] // ["BR", "US"] - países onde está disponível

  // Controle de sincronização
  isActive   Boolean  @default(true) @map("is_active")
  lastSyncAt DateTime @default(now()) @map("last_sync_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([provider, externalId])
  @@index([provider, isActive, currency])
  @@index([category])
  @@index([lastSyncAt])
  @@map("voucher_products")
}

model VoucherPrize {
  id      String @id @default(cuid())
  prizeId String @unique @map("prize_id") // 1:1 com Prize

  // Dados do provider
  provider   String // "tremendous", "giftty", "incentivar"
  externalId String @map("external_id") // ID do produto no provider

  // Valores permitidos
  minValue Decimal @map("min_value") @db.Decimal(10, 2)
  maxValue Decimal @map("max_value") @db.Decimal(10, 2)
  currency String  @default("BRL")

  // Metadados extras (flexível para dados específicos do provider)
  metadata Json?

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relacionamento 1:1 com Prize
  prize Prize @relation(fields: [prizeId], references: [id], onDelete: Cascade)

  @@index([provider])
  @@index([provider, externalId])
  @@map("voucher_prizes")
}

// ============================================================================
// WEBHOOK LOGS - Stores webhook events from providers (e.g., Tremendous)
// ============================================================================

model TremendousWebhookLog {
  id           String   @id @default(cuid())
  webhookUuid  String   @unique @map("webhook_uuid") // Tremendous uuid for idempotency
  event        String   // REWARDS.DELIVERY.SUCCEEDED, REWARDS.DELIVERY.FAILED, etc.
  payload      Json     // Full webhook payload
  processed    Boolean  @default(true) @map("processed")
  redemptionId String?  @map("redemption_id")
  createdAt    DateTime @default(now()) @map("created_at")

  redemption Redemption? @relation(fields: [redemptionId], references: [id])

  @@index([webhookUuid])
  @@index([event])
  @@index([processed, createdAt])
  @@map("tremendous_webhook_logs")
}
